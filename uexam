#!/usr/bin/env bash
set -euo pipefail

# ─── U-Exam CLI Installer & Manager ──────────────────────────────
VERSION="1.0.0"
REPO="https://github.com/littlebom/U-Exam.git"
INSTALL_DIR="${UEXAM_HOME:-$HOME/.uexam}"
ENV_FILE="$INSTALL_DIR/.env"
COMPOSE_FILE="$INSTALL_DIR/docker-compose.yml"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────

log()   { echo -e "${GREEN}✅ $1${NC}"; }
warn()  { echo -e "${YELLOW}⚠️  $1${NC}"; }
err()   { echo -e "${RED}❌ $1${NC}" >&2; }
info()  { echo -e "${CYAN}ℹ️  $1${NC}"; }
header(){ echo -e "\n${BLUE}━━━ $1 ━━━${NC}\n"; }

ask() {
  local prompt="$1" default="$2" result
  if [ -n "$default" ]; then
    read -rp "  $prompt [$default]: " result
    echo "${result:-$default}"
  else
    read -rp "  $prompt: " result
    echo "$result"
  fi
}

ask_password() {
  local prompt="$1" result
  read -rsp "  $prompt: " result
  echo
  echo "$result"
}

generate_secret() {
  openssl rand -base64 32 2>/dev/null || head -c 32 /dev/urandom | base64
}

generate_hex() {
  openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | xxd -p -c 64
}

check_docker() {
  if ! command -v docker &>/dev/null; then
    err "Docker not found. Please install Docker Desktop first."
    err "https://docs.docker.com/get-docker/"
    exit 1
  fi
  if ! docker info &>/dev/null; then
    err "Docker is not running. Please start Docker Desktop."
    exit 1
  fi
}

# ─── Commands ─────────────────────────────────────────────────────

cmd_launch() {
  echo -e "${BLUE}"
  echo "  ╔══════════════════════════════════════╗"
  echo "  ║   🎓 U-Exam Deployment Tool v$VERSION   ║"
  echo "  ╚══════════════════════════════════════╝"
  echo -e "${NC}"

  check_docker

  # Step 1: Clone or update
  header "Step 1/5: Download"
  if [ -d "$INSTALL_DIR/.git" ]; then
    info "Updating existing installation..."
    cd "$INSTALL_DIR" && git pull origin main
  else
    info "Downloading U-Exam..."
    git clone "$REPO" "$INSTALL_DIR"
  fi
  cd "$INSTALL_DIR"
  log "Source ready"

  # Step 2: Configuration
  header "Step 2/5: Configuration"

  local domain admin_email admin_pass db_pass redis_pass
  domain=$(ask "Domain (or localhost for local)" "localhost")
  admin_email=$(ask "Admin email" "admin@u-exam.com")
  admin_pass=$(ask_password "Admin password (min 8 chars)")

  if [ ${#admin_pass} -lt 8 ]; then
    err "Password must be at least 8 characters"
    exit 1
  fi

  db_pass=$(generate_secret)
  redis_pass=$(generate_secret)

  local app_url
  if [ "$domain" = "localhost" ]; then
    app_url="http://localhost:3001"
  else
    app_url="https://$domain"
  fi

  # SMTP (optional)
  local smtp_host="" smtp_user="" smtp_pass="" smtp_port="587"
  echo ""
  read -rp "  Enable SMTP email? [y/N]: " enable_smtp
  if [[ "$enable_smtp" =~ ^[Yy]$ ]]; then
    smtp_host=$(ask "SMTP host" "smtp.gmail.com")
    smtp_port=$(ask "SMTP port" "587")
    smtp_user=$(ask "SMTP user (email)" "")
    smtp_pass=$(ask_password "SMTP password (app password)")
  fi

  # Google OAuth (optional)
  local google_id="" google_secret=""
  echo ""
  read -rp "  Enable Google OAuth? [y/N]: " enable_google
  if [[ "$enable_google" =~ ^[Yy]$ ]]; then
    google_id=$(ask "Google Client ID" "")
    google_secret=$(ask_password "Google Client Secret")
  fi

  # Write .env
  cat > "$ENV_FILE" <<ENVEOF
# Generated by uexam launch — $(date)
APP_PORT=3001
POSTGRES_PORT=5433
REDIS_PORT=6380

POSTGRES_DB=u_exam
POSTGRES_USER=u_exam
POSTGRES_PASSWORD=$db_pass

REDIS_PASSWORD=$redis_pass

NEXTAUTH_URL=$app_url
NEXTAUTH_SECRET=$(generate_secret)
ENCRYPTION_KEY=$(generate_hex)

GOOGLE_CLIENT_ID=$google_id
GOOGLE_CLIENT_SECRET=$google_secret

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
ENVEOF

  log "Configuration saved"

  # Step 3: Build
  header "Step 3/5: Building"
  info "This may take 3-5 minutes on first run..."
  docker compose --env-file "$ENV_FILE" up -d --build
  log "All services started"

  # Step 4: Database
  header "Step 4/5: Database"
  info "Running migrations..."
  sleep 5  # Wait for PostgreSQL to be ready

  # Run migration from host or inside container
  docker compose --env-file "$ENV_FILE" exec -T postgres \
    psql -U u_exam -d u_exam -c "SELECT 1" &>/dev/null || {
    err "Database not ready. Waiting 10 more seconds..."
    sleep 10
  }

  # Use local prisma for migration
  if command -v npx &>/dev/null; then
    local db_url="postgresql://u_exam:${db_pass}@localhost:5433/u_exam"
    DATABASE_URL="$db_url" npx prisma migrate deploy 2>/dev/null || {
      warn "Migration via host failed, trying alternative..."
    }
    DATABASE_URL="$db_url" npx prisma db seed 2>/dev/null || {
      warn "Seed skipped (run 'uexam seed' later)"
    }
  else
    warn "Node.js not found locally. Run 'uexam migrate' and 'uexam seed' manually."
  fi
  log "Database ready"

  # Step 5: Done
  header "Step 5/5: Complete!"
  echo -e "${GREEN}"
  echo "  ╔══════════════════════════════════════════════╗"
  echo "  ║  🎉 U-Exam is running!                       ║"
  echo "  ║                                              ║"
  echo "  ║  URL:   $app_url"
  echo "  ║  Admin: $admin_email"
  echo "  ║                                              ║"
  echo "  ║  Commands:                                   ║"
  echo "  ║    uexam start    — Start services           ║"
  echo "  ║    uexam stop     — Stop services            ║"
  echo "  ║    uexam logs     — View logs                ║"
  echo "  ║    uexam status   — Check status             ║"
  echo "  ║    uexam backup   — Backup database          ║"
  echo "  ║    uexam update   — Update to latest         ║"
  echo "  ╚══════════════════════════════════════════════╝"
  echo -e "${NC}"
}

cmd_start() {
  check_docker
  cd "$INSTALL_DIR"
  docker compose --env-file "$ENV_FILE" up -d
  log "U-Exam started"
  cmd_status
}

cmd_stop() {
  cd "$INSTALL_DIR"
  docker compose --env-file "$ENV_FILE" down
  log "U-Exam stopped"
}

cmd_restart() {
  cd "$INSTALL_DIR"
  docker compose --env-file "$ENV_FILE" restart
  log "U-Exam restarted"
}

cmd_status() {
  cd "$INSTALL_DIR"
  echo ""
  docker compose --env-file "$ENV_FILE" ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || \
    docker compose --env-file "$ENV_FILE" ps
  echo ""
}

cmd_logs() {
  cd "$INSTALL_DIR"
  local service="${1:-}"
  if [ -n "$service" ]; then
    docker compose --env-file "$ENV_FILE" logs -f "$service"
  else
    docker compose --env-file "$ENV_FILE" logs -f
  fi
}

cmd_backup() {
  cd "$INSTALL_DIR"
  local backup_dir="$INSTALL_DIR/backups"
  local timestamp=$(date +%Y%m%d_%H%M%S)
  local backup_file="$backup_dir/u_exam_${timestamp}.sql.gz"

  mkdir -p "$backup_dir"

  info "Backing up database..."
  docker compose --env-file "$ENV_FILE" exec -T postgres \
    pg_dump -U u_exam u_exam | gzip > "$backup_file"

  local size=$(du -h "$backup_file" | cut -f1)
  log "Backup saved: $backup_file ($size)"
}

cmd_restore() {
  local backup_file="${1:-}"
  if [ -z "$backup_file" ]; then
    # Show available backups
    local backup_dir="$INSTALL_DIR/backups"
    if [ -d "$backup_dir" ] && [ "$(ls -A "$backup_dir" 2>/dev/null)" ]; then
      info "Available backups:"
      ls -lh "$backup_dir"/*.sql.gz 2>/dev/null
      echo ""
      err "Usage: uexam restore <backup-file>"
    else
      err "No backups found. Run 'uexam backup' first."
    fi
    exit 1
  fi

  cd "$INSTALL_DIR"
  warn "This will REPLACE all data in the database!"
  read -rp "  Continue? [y/N]: " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    info "Cancelled"
    exit 0
  fi

  info "Restoring from $backup_file..."
  gunzip -c "$backup_file" | docker compose --env-file "$ENV_FILE" exec -T postgres \
    psql -U u_exam u_exam
  log "Database restored"
}

cmd_update() {
  check_docker
  cd "$INSTALL_DIR"

  header "Updating U-Exam"

  info "Pulling latest code..."
  git pull origin main

  info "Rebuilding..."
  docker compose --env-file "$ENV_FILE" up -d --build

  info "Running migrations..."
  sleep 5
  if command -v npx &>/dev/null; then
    source "$ENV_FILE" 2>/dev/null || true
    local db_url="postgresql://u_exam:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT:-5433}/u_exam"
    DATABASE_URL="$db_url" npx prisma migrate deploy 2>/dev/null || warn "Migration skipped"
  fi

  log "U-Exam updated to latest version"
}

cmd_migrate() {
  cd "$INSTALL_DIR"
  source "$ENV_FILE" 2>/dev/null || true
  local db_url="postgresql://u_exam:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT:-5433}/u_exam"
  DATABASE_URL="$db_url" npx prisma migrate deploy
  log "Migrations applied"
}

cmd_seed() {
  cd "$INSTALL_DIR"
  source "$ENV_FILE" 2>/dev/null || true
  local db_url="postgresql://u_exam:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT:-5433}/u_exam"
  DATABASE_URL="$db_url" npx prisma db seed
  log "Seed data created"
}

cmd_config() {
  if [ -f "$ENV_FILE" ]; then
    info "Config file: $ENV_FILE"
    echo ""
    grep -v "PASSWORD\|SECRET\|KEY" "$ENV_FILE" | grep -v "^#" | grep -v "^$"
    echo ""
    info "(Secrets hidden — edit directly: $ENV_FILE)"
  else
    err "No config found. Run 'uexam launch' first."
  fi
}

cmd_help() {
  echo -e "${BLUE}🎓 U-Exam CLI v$VERSION${NC}"
  echo ""
  echo "Usage: uexam <command>"
  echo ""
  echo "Commands:"
  echo "  launch     First-time setup (config → build → migrate → seed)"
  echo "  start      Start all services"
  echo "  stop       Stop all services"
  echo "  restart    Restart all services"
  echo "  status     Show service status"
  echo "  logs       View logs (uexam logs [app|postgres|redis|nginx])"
  echo "  config     Show current configuration"
  echo "  backup     Backup database"
  echo "  restore    Restore database from backup"
  echo "  update     Pull latest code + rebuild + migrate"
  echo "  migrate    Run database migrations"
  echo "  seed       Seed sample data"
  echo "  help       Show this help"
  echo ""
}

# ─── Main ─────────────────────────────────────────────────────────

case "${1:-help}" in
  launch)   cmd_launch ;;
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  restart)  cmd_restart ;;
  status)   cmd_status ;;
  logs)     cmd_logs "${2:-}" ;;
  config)   cmd_config ;;
  backup)   cmd_backup ;;
  restore)  cmd_restore "${2:-}" ;;
  update)   cmd_update ;;
  migrate)  cmd_migrate ;;
  seed)     cmd_seed ;;
  help|--help|-h) cmd_help ;;
  version|--version|-v) echo "uexam v$VERSION" ;;
  *) err "Unknown command: $1"; cmd_help; exit 1 ;;
esac
